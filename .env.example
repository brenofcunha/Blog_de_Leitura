DJANGO_SETTINGS_MODULE=config.settings.development

# Development
DJANGO_SECRET_KEY=dev-only-change-me
USE_POSTGRES=0
MAX_PORTAL_USERS=5

# Production
# DJANGO_SETTINGS_MODULE=config.settings.production
# DJANGO_SECRET_KEY=generate-a-strong-secret
# DJANGO_ALLOWED_HOSTS=seudominio.com,www.seudominio.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://seudominio.com,https://www.seudominio.com
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_USE_X_FORWARDED_PROTO=1
# DJANGO_SECURE_HSTS_SECONDS=31536000

# PostgreSQL (required in production)
POSTGRES_DB=blog_leitura
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
