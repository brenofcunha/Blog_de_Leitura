# Settings module
DJANGO_SETTINGS_MODULE=config.settings.development

# Application and security
DEBUG=1
DJANGO_SECRET_KEY=dev-only-change-me
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
MAX_PORTAL_USERS=5

# Database selection:
# DATABASE_ENGINE=sqlite | postgresql | mysql
DATABASE_ENGINE=sqlite

# Generic DB aliases (optional)
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=

# PostgreSQL
POSTGRES_DB=blog_leitura
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# MySQL (HostGator common setup)
MYSQL_DATABASE=blog_leitura
MYSQL_USER=blog_user
MYSQL_PASSWORD=change-me
MYSQL_HOST=localhost
MYSQL_PORT=3306

# SQLite
SQLITE_PATH=

# Production security (example)
# DJANGO_SETTINGS_MODULE=config.settings.production
# DEBUG=0
# DJANGO_SECRET_KEY=generate-a-strong-secret
# ALLOWED_HOSTS=seudominio.com,www.seudominio.com
# CSRF_TRUSTED_ORIGINS=https://seudominio.com,https://www.seudominio.com
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_USE_X_FORWARDED_PROTO=1
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
# DJANGO_SECURE_HSTS_PRELOAD=1

# Optional S3 uploads (if all variables below exist, S3 is enabled)
# AWS_STORAGE_BUCKET_NAME=your-bucket
# AWS_S3_REGION_NAME=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_CUSTOM_DOMAIN=cdn.seudominio.com
# AWS_MEDIA_LOCATION=media
